{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@jmapfe/app-core": ["packages/app-core/src/index.ts"],
      "@jmapfe/jmap-calendar": ["packages/jmap-calendar/src/index.ts"],
      "@jmapfe/jmap-contacts": ["packages/jmap-contacts/src/index.ts"],
      "@jmapfe/jmap-core": ["packages/jmap-core/src/index.ts"],
      "@jmapfe/jmap-extensions": ["packages/jmap-extensions/src/index.ts"],
      "@jmapfe/jmap-mail": ["packages/jmap-mail/src/index.ts"],
      "@jmapfe/mime": ["packages/mime/src/index.ts"],
      "@jmapfe/openpgp": ["packages/openpgp/src/index.ts"],
      "@jmapfe/platform": ["packages/platform/src/index.ts"],
      "@jmapfe/store": ["packages/store/src/index.ts"],
      "@jmapfe/sync": ["packages/sync/src/index.ts"],
      "@jmapfe/test-fixtures": ["packages/test-fixtures/src/index.ts"],
      "@jmapfe/ui": ["packages/ui/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts"],
  "exclude": ["node_modules"]
}
