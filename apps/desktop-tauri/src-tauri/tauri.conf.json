{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jmapfe",
  "version": "0.0.0",
  "identifier": "app.jmapfe.desktop",
  "build": {
    "beforeDevCommand": "npm --workspace @jmapfe/web run start:clear",
    "beforeBuildCommand": "npm --workspace @jmapfe/web run web",
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:8081"
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"]
  },
  "app": {
    "windows": [
      {
        "title": "jmapfe",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  }
}
